{
  "name": "eh-skills",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch scripts/start-server.ts",
    "build": "bun run scripts/build-assets.ts",
    "start": "bun run scripts/start-server.ts",
    "lint": "bun x eslint .",
    "format": "bun x prettier --write .",
    "format:check": "bun x prettier --check .",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test tests/*.test.ts",
    "test:coverage": "bun test tests/*.test.ts --coverage --coverage-reporter=lcov --coverage-reporter=text",
    "coverage:check": "bun run scripts/coverage-check.ts",
    "test:e2e": "bun x playwright test",
    "test:smoke": "bun x playwright test tests/e2e/smoke.e2e.ts",
    "validate": "bun run typecheck && bun run lint && bun run format:check && bun run test && bun run test:coverage && bun run coverage:check && bun run test:smoke"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "chart.js": "^4.5.1",
    "hono": "^4.10.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.10",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "linkedom": "^0.18.12",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
